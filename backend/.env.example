# Application environment
APP_ENV=development
# Note: /docs, /redoc, and /openapi.json are disabled when APP_ENV=production

# Logging
LOG_LEVEL=INFO
LOG_USE_UTC=false
# LOG_FORMAT=JSON        # TEXT (default) or JSON — use JSON for log shipping
# See backend/docs/logging-integrations.md for platform integration guides

# Upload validation
MAX_UPLOAD_SIZE_MB=10

# ── LLM & Embedding Providers ─────────────────────────────────────────────
# Provider: gemini (default), openai, or ollama
# LLM_PROVIDER=gemini
# LLM_MODEL=                          # optional; provider picks its default
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=                    # optional; provider picks its default
# EMBEDDING_DIM=                      # auto-detected from model; override for unknown models
                                      # Switching providers requires re-embedding + fresh DB

# Gemini (if LLM_PROVIDER=gemini or EMBEDDING_PROVIDER=gemini)
GEN_AI_KEY=your_google_ai_studio_api_key_here
# LLM_HTTP_TIMEOUT_MS=60000           # Gemini HTTP client timeout (milliseconds)

# OpenAI (if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=                        # optional; for OpenAI-compatible APIs
                                           # e.g. https://openrouter.ai/api/v1

# Ollama (if LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Database (optional - Docker Compose provides these)
# Only needed if connecting outside Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# ── Chunking ──────────────────────────────────────────────────────────────
# Strategy: fixed (default), paragraph, or semantic
# CHUNKING_STRATEGY=fixed
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ── Query Transformations ─────────────────────────────────────────────────
# QUERY_TRANSFORMATION_ENABLED=false
# QUERY_TRANSFORMATION_STRATEGY=rewrite  # rewrite | expand | stepback

# ── LLM / Prompt ──────────────────────────────────────────────────────────
# Path to system prompt file (default: backend/prompts/default_system.txt)
# SYSTEM_PROMPT_PATH=
# LLM_TEMPERATURE=0.2
# LLM_MAX_OUTPUT_TOKENS=1024

# ── Queue Backend ─────────────────────────────────────────────────────────
# QUEUE_BACKEND=memory     # memory (default) or redis
# REDIS_URL=redis://localhost:6379/0

# ── Background ingestion queue ────────────────────────────────────────────
# QUEUE_RETRY_BASE_DELAY=2.0  # base seconds for queue job retry backoff

# Status health checks
HEALTH_CHECK_CACHE_TTL_SECONDS=60

# ── SQLAlchemy / PostgreSQL ───────────────────────────────────────────────
# SQLALCHEMY_STATEMENT_TIMEOUT_SEC=30

# ── Supabase ──────────────────────────────────────────────────────────────
# SUPABASE_HTTP_TIMEOUT_SEC=30

# ── CORS ──────────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000
# Note: wildcard (*) is not valid with allow_credentials=True
# Use comma-separated explicit origins for multiple allowed origins

# ── Rate Limiting ─────────────────────────────────────────────────────────
# Per-IP request limits. Format: "N/period" (minute, hour, day)
# RATE_LIMIT_UPLOAD=20/hour
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_CHAT_BATCH=10/minute
# RATE_LIMIT_STATUS=10/minute
# RATE_LIMIT_QUEUE_STATS=10/minute
# RATE_LIMIT_DOCUMENT_STATUS=120/minute
# RATE_LIMIT_DOCUMENT_DELETE=60/hour
